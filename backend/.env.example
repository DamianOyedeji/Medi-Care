# Server Configuration
NODE_ENV=production
PORT=5000
HOST=0.0.0.0
CLIENT_URL=https://medi-care-frontend.onrender.com

# CORS Origins (comma-separated, set to your Render frontend URL)
CORS_ORIGINS=https://medi-care-frontend.onrender.com

# Supabase Configuration (FREE TIER)
# Get these from: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# OpenAI Configuration (PAY-PER-USE)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key

# HuggingFace Configuration (FREE)
# Get from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Gmail SMTP for Crisis Emails (FREE)
# Guide: https://support.google.com/accounts/answer/185833
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Crisis Escalation
CRISIS_EMAIL_RECIPIENTS=your-email@gmail.com

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
CRISIS_RATE_LIMIT_MAX=5

# Logging
LOG_LEVEL=info